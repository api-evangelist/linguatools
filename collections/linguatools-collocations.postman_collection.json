{
  "item": [
    {
      "id": "8087448c-9809-4e44-bde4-81ad8c3ff7df",
      "name": "Collocations",
      "description": {
        "content": "Operations for retrieving English collocations.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "31290205-0bb5-461d-9c51-a602fc03b508",
          "name": "Get collocations for a word",
          "request": {
            "name": "Get collocations for a word",
            "description": {
              "content": "Returns collocations for the supplied query word. Supports filtering by syntactic relation, minimum significance score, and (in v2) part of speech. Results include the collocation text, relation type, significance score, and up to three example sentences.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "query",
                  "value": "<string>",
                  "description": "(Required) The query word (case-insensitive)."
                },
                {
                  "disabled": false,
                  "key": "lang",
                  "value": "<string>",
                  "description": "(Required) ISO 639-1 language code. Currently only `en` is supported."
                },
                {
                  "disabled": false,
                  "key": "relation",
                  "value": "<string>",
                  "description": "Syntactic relation type (case-sensitive). Examples include `V:obj:N` (verb-object), `N:mod:Adj` (noun-adjective modifier), `Adj:mod:N`, `V:subj:N`, `N:prep:N`, `V:adv:Adv`."
                },
                {
                  "disabled": false,
                  "key": "min_sig",
                  "value": "<integer>",
                  "description": "Minimum significance threshold. Values must be 100 or greater."
                },
                {
                  "disabled": false,
                  "key": "pos",
                  "value": "<string>",
                  "description": "Part of speech filter (v2 only). One of `V` (verb), `Vinf` (infinitive verb), `N` (noun), `Adj` (adjective), `Adv` (adverb)."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) Your RapidAPI subscription key.",
                "key": "X-RapidAPI-Key",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "(Required) Must be set to `linguatools-collocations.p.rapidapi.com`.",
                "key": "X-RapidAPI-Host",
                "value": "linguatools-collocations.p.rapidapi.com"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "f944adf6-c5b3-460c-9777-2a33c7bca116",
